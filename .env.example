# Environment Variables for CCTV Analytics Platform

# =================================
# DJANGO SETTINGS
# =================================
DEBUG=True
SECRET_KEY=your-secret-key-change-this-in-production-with-strong-random-key
DJANGO_SETTINGS_MODULE=config.settings.local
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# =================================
# DATABASE
# =================================
DB_ENGINE=django.db.backends.postgresql
DB_NAME=cctv_analytics
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=postgres
DB_PORT=5432

# =================================
# REDIS & CELERY
# =================================
REDIS_URL=redis://redis:6379/2
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# =================================
# SECURITY
# =================================
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
ENCRYPTION_KEY=change-me-to-32-byte-key-for-production

# =================================
# CORS
# =================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# =================================
# EMAIL CONFIGURATION
# =================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@cctvanalytics.com

# =================================
# VISION & ANALYTICS
# =================================
VISION_WORKER_ENABLED=True
STREAM_PROCESSING_INTERVAL=5
FRAME_SAMPLING_RATE=5
SNAPSHOT_RETENTION_DAYS=7

# =================================
# WEBHOOKS
# =================================
WEBHOOK_TIMEOUT=10
WEBHOOK_MAX_RETRIES=3

# =================================
# FRONTEND
# =================================
VITE_API_URL=http://localhost:8000/api/v1
